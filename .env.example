# Turso Database
DATABASE_URL=libsql://your-database.turso.io
DATABASE_AUTH_TOKEN=your-auth-token

# Payload
PAYLOAD_SECRET=your-secret-here-at-least-32-characters

# MailChimp — used by /api/newsletter to subscribe via the v3 API.
# The `-usNN` suffix identifies the datacenter; the route parses it automatically.
MAILCHIMP_API_KEY=your-key-here-usNN
